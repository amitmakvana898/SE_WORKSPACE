2) Build a Flipkart-style discount calculator: given product price, discount percentage, and a boolean isMember, use arithmetic and logical operators to calculate the final price
  (apply an extra 5% off if isMember is true).

   #include<stdio.h>
   #include<conio.h>

    void main()
{
    float price, finalPrice;
    int discount, isMember;

    clrscr();

    printf("Enter Product Price: ");
    scanf("%f", &price);

    printf("Enter Discount Percentage: ");
    scanf("%d", &discount);

    printf("Are you a Member? (1 = Yes, 0 = No): ");
    scanf("%d", &isMember);

    // Apply discount
    finalPrice = price - (price * discount / 100);

    // Extra 5% discount for members
    if (isMember == 1)
    {
        finalPrice = finalPrice - (finalPrice * 5 / 100);
    }

    printf("\nFinal Price = %.2f", finalPrice);

