1. Create a simple IPL Fan Bot that takes your favorite IPL team name as input and uses if-else-if statements to print a unique cheer message for each team 
   (e.g., 'Go Mumbai Indians!', 'Chennai Super Kings for the win!'). If the team is not recognized, print 'Team not found!'


#include <stdio.h>
#include <conio.h>

void main()
{
    char team = 'R';

    if (team == 'M')
        printf(" Go Mumbai Indians!");
    else if (team == 'C')
        printf(" Go Chennai Super Kings!");
    else if (team == 'R')
        printf(" win Royal Challengers Bangalore!");
    else if (team == 'K')
        printf(" Go Kolkata Knight Riders!");
    else
        printf("Team not found!");

    getch();
}

