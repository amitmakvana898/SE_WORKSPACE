3. Create a Flipkart discount calculator that asks the user for the total cart amount. Use nested if statements to check: if amount > 2000, apply 20% discount; else if amount > 1000, apply 10% discount; else, no discount.
   Print the final amount to pay. Use nested ifs to check each discount slab.

#include <stdio.h>
#include <conio.h>

void main()
{
    float amount = 2500, finalAmount;

    if (amount > 1000)
    {
        if (amount > 2000)
            finalAmount = amount - (amount * 20 / 100);
        else
            finalAmount = amount - (amount * 10 / 100);
    }
    else
        finalAmount = amount;

    printf("Final Amount to Pay = Rs. %f", finalAmount);

    getch();
}


